# Base de données Postgres (docker-compose local)
DATABASE_URL=postgresql://kinhale:kinhale_dev_secret@localhost:5434/kinhale_dev

# Redis (docker-compose local)
REDIS_URL=redis://:kinhale_redis_dev@localhost:6379

# JWT
JWT_SECRET=dev-secret-minimum-32-characters-long-for-local-testing
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d

# Serveur
PORT=3002
NODE_ENV=development
