{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js 15 (app router, React 19)",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": false,
    "noEmit": true,
    "plugins": [{ "name": "next" }]
  }
}
