{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native / Expo SDK 52 (iOS + Android)",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "allowJs": false,
    "noEmit": true
  }
}
